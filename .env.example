# Core Discord bot settings
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-client-id
DISCORD_GUILD_ID=your-test-server-id
DISCORD_RESPOND_TO_MENTIONS_ONLY=true

# Admin and app runtime
ADMIN_SECRET=choose-a-strong-admin-password
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# OpenRouter settings
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Cadence Lite

# Model defaults
CHAT_LLM_MODEL=openai/gpt-5.4
IMAGE_LLM_MODEL=openai/gpt-5.4-mini
EMBEDDING_LLM_MODEL=openai/text-embedding-3-small
TRANSCRIPTION_LLM_MODEL=google/gemini-2.5-flash

# Prompt and personality settings are normally managed in the admin UI
# and stored in Postgres. The env vars below are only legacy startup fallbacks.
# Prompt defaults
CHAT_PROMPT_PERSONA_NAME=Cadence
CHAT_PROMPT_USER_NAME=User
CHAT_PROMPT_PERSONA_PROFILE=
CHAT_PROMPT_TONE_GUIDELINES=
CHAT_PROMPT_USER_PROFILE=
CHAT_PROMPT_COMPANION_PURPOSE=
CHAT_PROMPT_BOUNDARY_RULES=
CHAT_HISTORY_LIMIT=20
CHAT_INCLUDE_TIME_CONTEXT=true
CHAT_TIMEZONE=UTC

# Persistence
DATABASE_URL=

# Memory / vector search
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=cadence-memory
MEMORY_USER_SCOPE=user
