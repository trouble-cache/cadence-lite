# Core Discord bot settings
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-client-id
DISCORD_GUILD_ID=your-test-server-id
DISCORD_RESPOND_TO_MENTIONS_ONLY=true

# Railway / app runtime
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
DEFAULT_CHAT_MODE=default

# Future model provider settings
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.4
OPENAI_IMAGE_MODEL=gpt-4o
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_SUMMARY_MODEL=gpt-5.4
CHAT_PROMPT_PERSONA_NAME=Cadence
CHAT_PROMPT_PERSONA_PROFILE=
CHAT_PROMPT_TONE_GUIDELINES=
CHAT_PROMPT_USER_PROFILE=
CHAT_PROMPT_COMPANION_PURPOSE=
CHAT_PROMPT_BOUNDARY_RULES=

# Persistence
DATABASE_URL=

# Future memory / vector search settings
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=cadence-memory
